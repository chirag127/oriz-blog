---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { FinishSignIn } from '@chirag127/oriz-ui'
---

<BaseLayout
  title="Finishing sign-in — Blog"
  description="Completing email-link sign-in."
  noindex={true}
  hideSidebar={true}
>
  <section class="finish">
    <FinishSignIn client:load />
  </section>
</BaseLayout>

<style>
  .finish { padding-block: 5rem 4rem; text-align: center; max-width: var(--container-prose, 720px); margin-inline: auto; }
</style>
