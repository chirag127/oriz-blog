---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { AccountPanel } from '@chirag127/oriz-ui'
---

<BaseLayout
  title="Account — Blog"
  description="Sign in to oriz. One account works across every oriz site."
  noindex={true}
  hideSidebar={true}
>
  <header class="page-head">
    <p class="eyebrow"><a href="/">Blog</a> / Account</p>
    <h1>Account</h1>
    <p class="lede">
      One sign-in works across every oriz site (oriz.in, blog.oriz.in,
      books.oriz.in, …). Bookmarks and reading history follow you.
    </p>
  </header>

  <section class="panel">
    <AccountPanel client:load />
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); max-width: var(--container-prose, 720px); margin-inline: auto; }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .lede { color: var(--color-fg-muted); margin: 0.75rem 0 0; font-size: 1.0625rem; max-width: 56ch; }
  .panel { padding-block: 2rem 4rem; max-width: var(--container-prose, 720px); margin-inline: auto; }
</style>
