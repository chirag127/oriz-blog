---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { ContactForm } from '@chirag127/oriz-ui'

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="Contact — Blog"
  description="Get in touch about anything on blog.oriz.in."
  hideSidebar={true}
>
  <header class="page-head">
    <p class="eyebrow"><a href="/">Blog</a> / Contact</p>
    <h1>Contact</h1>
  </header>

  <section class="prose">
    <p class="lede">
      The fastest way to reach me about a blog post — typo, broken link,
      follow-up question, or pitch — is email:
      <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
    </p>
    <p>
      Or use the form below — it posts to Web3Forms which forwards to my inbox.
      No data is stored on this site.
    </p>

    <ContactForm
      client:load
      web3formsKey={web3formsKey}
      fromName="blog.oriz.in contact form"
    />

    <p class="meta">
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under IT Rules 2021).
    </p>
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); max-width: var(--container-prose, 720px); margin-inline: auto; }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  .eyebrow a:hover { color: var(--color-fg); }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .prose { padding-block: 2.5rem 4rem; color: var(--color-prose); line-height: 1.7; font-size: 1.0625rem; max-width: var(--container-prose, 720px); margin-inline: auto; }
  .prose .lede { font-size: 1.1875rem; color: var(--color-fg); margin: 0 0 1.25rem; }
  .prose a { color: var(--color-accent); }
  .meta { font-size: 0.875rem; color: var(--color-fg-muted); margin-top: 2rem; }
</style>
