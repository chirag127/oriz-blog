---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
const latestPosts = sortedPosts.slice(0, 6)
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].slice(0, 14)

const folderMap = new Map<string, typeof allPosts>()
for (const post of allPosts) {
  const slashIdx = post.id.indexOf('/')
  if (slashIdx === -1) continue
  const folder = post.id.substring(0, slashIdx)
  const arr = folderMap.get(folder) ?? []
  arr.push(post)
  folderMap.set(folder, arr)
}
const seriesPreview = [...folderMap.entries()].slice(0, 3).map(([folder, posts]) => {
  const indexPost = posts.find((p) => p.id === `${folder}/index`)
  const rep = indexPost ?? posts[0]
  return {
    slug: folder,
    title: rep.data.title,
    description: rep.data.description,
    postCount: posts.length,
  }
})

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog — oriz',
  url: 'https://blog.oriz.in/',
  description: 'Long-form writing on engineering, finance, and books — by Chirag Singhal.',
  author: { '@type': 'Person', name: 'Chirag Singhal', url: 'https://oriz.in/about/' },
}

function slugifyTag(value: string): string {
  return value.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
}

function fmtDate(d: Date): string {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
}
---

<BaseLayout
  title="Blog — oriz"
  description="Long-form writing on engineering, finance, and books — by Chirag Singhal."
  jsonLd={jsonLd}
>
  <section class="hero">
    <p class="eyebrow">✍️ <span>The oriz blog</span></p>
    <h1 class="hero-h">Long-form writing on engineering, finance, and books.</h1>
    <p class="hero-lede">
      {allPosts.length} posts so far. Software, AI agents, finance tooling,
      books — and the things I build at <a href="https://oriz.in">oriz.in</a>.
    </p>
    <div class="hero-cta">
      <a href="/blog/" class="btn btn-primary">Read all posts →</a>
      <a href="/about/" class="btn">About</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2 class="section-h">Latest posts</h2>
      <a class="section-link" href="/blog/">All posts →</a>
    </div>
    <ul class="post-grid">
      {latestPosts.map((post) => (
        <li>
          <a class="post-card" href={`/blog/${post.id}`}>
            <span class="post-cat">{post.data.category}</span>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>
            <time class="post-date" datetime={post.data.pubDate.toISOString()}>
              {fmtDate(post.data.pubDate)}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </section>

  {seriesPreview.length > 0 && (
    <section class="section">
      <div class="section-head">
        <h2 class="section-h">Browse series</h2>
        <a class="section-link" href="/series/">All series →</a>
      </div>
      <ul class="series-grid">
        {seriesPreview.map((s) => (
          <li>
            <a class="series-card" href={`/series/${s.slug}`}>
              <h3>{s.title}</h3>
              <p>{s.description}</p>
              <span class="series-meta">{s.postCount} posts</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {allTags.length > 0 && (
    <section class="section">
      <h2 class="section-h">Browse by tag</h2>
      <ul class="tag-cloud">
        {allTags.map((t) => (
          <li><a href={`/tags/${slugifyTag(t)}/`} class="tag-chip">#{t}</a></li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
  .hero { padding-block: 4rem 2rem; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    color: var(--color-fg-muted);
    font-size: 0.75rem;
    margin: 0 0 1.25rem;
  }
  .hero-h {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 1rem;
    max-width: 22ch;
  }
  .hero-lede {
    color: var(--color-fg-muted);
    font-size: 1.0625rem;
    max-width: 60ch;
    margin: 0 0 1.5rem;
  }
  .hero-lede a { color: var(--color-accent); }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.625rem; }
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    height: 40px; padding-inline: 1.125rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    color: var(--color-fg);
    font-weight: 500;
    text-decoration: none;
  }
  .btn:hover { border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border)); color: var(--color-fg); }
  .btn-primary { background: var(--color-accent); color: var(--color-accent-fg); border-color: var(--color-accent); }
  .btn-primary:hover { color: var(--color-accent-fg); }

  .section { padding-block: 2.5rem; border-top: 1px solid var(--color-border); }
  .section:first-of-type { border-top: 0; }
  .section-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.25rem; gap: 1rem; }
  .section-h {
    font-family: var(--font-serif);
    font-size: 1.5rem; font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .section-link { font-size: 0.875rem; color: var(--color-fg-muted); text-decoration: none; }
  .section-link:hover { color: var(--color-fg); }

  .post-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .post-card {
    display: grid; gap: 0.5rem;
    padding: 1.125rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    color: var(--color-fg);
    text-decoration: none;
    transition: border-color 120ms;
  }
  .post-card:hover { border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border)); color: var(--color-fg); }
  .post-cat {
    align-self: start;
    padding: 0.125rem 0.5rem;
    background: var(--color-bg-muted);
    border-radius: 0.25rem;
    color: var(--color-fg-muted);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .post-title { margin: 0; font-size: 1.0625rem; font-weight: 600; line-height: 1.35; }
  .post-desc { margin: 0; color: var(--color-fg-muted); font-size: 0.9375rem; }
  .post-date { color: var(--color-fg-soft); font-size: 0.8125rem; }

  .series-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .series-card {
    display: block;
    padding: 1.125rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    color: var(--color-fg);
    text-decoration: none;
  }
  .series-card:hover { border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border)); }
  .series-card h3 { margin: 0 0 0.375rem; font-size: 1.0625rem; font-weight: 600; }
  .series-card p { margin: 0 0 0.5rem; color: var(--color-fg-muted); font-size: 0.9375rem; }
  .series-meta { color: var(--color-fg-soft); font-size: 0.8125rem; }

  .tag-cloud { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag-chip {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.8125rem;
    color: var(--color-fg-muted);
    text-decoration: none;
  }
  .tag-chip:hover { color: var(--color-fg); border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border)); }
</style>
