---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const tagsMap = new Map();

  allPosts.forEach((post) => {
    if (post.data.tags) {
      post.data.tags.forEach((tag) => {
        const slug = tag.toLowerCase().replace(/\//g, "-").replace(/\s+/g, "-");
        if (!tagsMap.has(slug)) {
          tagsMap.set(slug, {
            originalTag: tag,
            posts: [],
          });
        }
        const group = tagsMap.get(slug);
        if (group && !group.posts.includes(post)) {
          group.posts.push(post);
        }
      });
    }
  });

  return Array.from(tagsMap.entries()).map(
    ([slug, { originalTag, posts }]) => ({
      params: { tag: slug },
      props: { tag: originalTag, posts },
    }),
  );
}

const { tag, posts } = Astro.props;
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title={`Tag: ${tag}`}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8">
      <a href="/tags" class="text-sm text-accent-light hover:underline">← All tags</a>
      <h1 class="text-3xl font-bold mt-2">
        #{tag}
      </h1>
      <p class="text-text-tertiary mt-1">
        {sortedPosts.length} post{sortedPosts.length !== 1 ? "s" : ""}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </div>
</BaseLayout>
